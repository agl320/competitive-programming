    #include <iostream>
    #include <vector>
    #include <algorithm>

    using namespace std;

    int main() {
        ios::sync_with_stdio(false);
        cin.tie(0);

        long long n, m, type, l, r;
        cin >> n;

        vector<long long> v(n);
  
        for(int i = 0; i < n; i++) {
            cin >> v[i];
        }

        vector<long long> sorted_v = v;
        sort(sorted_v.begin(), sorted_v.end());

        vector<long long> prefix(n+1, 0);
        vector<long long> prefix_sorted(n+1, 0);

        for(int i = 1; i < n + 1; i++) {
            prefix[i] = prefix[i-1] + v[i-1];
        }
        for(int i = 1; i < n + 1; i++) {
            prefix_sorted[i] = prefix_sorted[i-1] + sorted_v[i-1];
        }

        cin >> m;
        
        for (int i = 0; i < m; i++){
            cin >> type >> l >> r;
            if (type == 1) {
                cout << prefix[r] - prefix[l-1] << "\n";
            }
            else {
                cout << prefix_sorted[r] - prefix_sorted[l-1] << "\n";
            }
        }        

        return 0;
    }